<Window x:Class="WpfApplication.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApplication"
        mc:Ignorable="d"
        Language="en-US"
        Title="System Zarządzania Zawodnikami" Height="650" Width="900">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Validation.ErrorTemplate" Value="{x:Null}"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Height" Value="25"/>
        </Style>
    </Window.Resources>

    <StackPanel Orientation="Vertical" Margin="10">

        <GroupBox Header="Dane Zawodnika" Margin="0,0,0,10">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Label Content="Imię:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1" 
                         Text="{Binding Path=ZawodnikRecord.Imie, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <Label Content="Kondycja :" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" Width="100" HorizontalAlignment="Left"
                         Text="{Binding Path=ZawodnikRecord.Kondycja, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>

                <TextBlock Grid.Row="1" Grid.Column="1" Visibility="Collapsed" 
                           Text="{Binding Path=ZawodnikRecord.ZawodnikId}"/>

                <Label Content="Czy Kontuzja (True/False):" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox Grid.Row="2" Grid.Column="1" Width="100" HorizontalAlignment="Left"
                         Text="{Binding Path=ZawodnikRecord.CzyKontuzja, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <Label Content="Nr Koszulki:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox Grid.Row="3" Grid.Column="1" Width="100" HorizontalAlignment="Left"
                         Text="{Binding Path=ZawodnikRecord.NrKoszulki, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <Label Content="Klub ID:" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox Grid.Row="4" Grid.Column="1" Width="100" HorizontalAlignment="Left"
                         Text="{Binding Path=ZawodnikRecord.KlubId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <Label Content="Statystyka ID:" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox Grid.Row="5" Grid.Column="1" Width="100" HorizontalAlignment="Left"
                         Text="{Binding Path=ZawodnikRecord.StatystykaId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </GroupBox>

        <GroupBox Header="Statystyki Biznesowe (Klub ID: 1)" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Padding="15,5" Margin="10">
                    <StackPanel>
                        <Label Content="Łączna liczba goli" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding LaczneGoleKlubu}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Padding="15,5" Margin="10">
                    <StackPanel>
                        <Label Content="Śr. kondycja zdrowych" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding SredniaKondycjaZdrowych, StringFormat={}{0:F2}}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Padding="15,5" Margin="10">
                    <StackPanel>
                        <Label Content="Liczba zawodników" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding LiczbaZawodnikowKlubu}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </GroupBox>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
            <Button Content="Zapisz" Width="100" Height="30" Margin="5"
                    Command="{Binding SaveCommand}" Background="LightGreen"/>
            <Button Content="Anuluj / Reset" Width="100" Height="30" Margin="5"
                    Command="{Binding ResetCommand}"/>
        </StackPanel>

        <GroupBox Header="Lista Zawodników">
            <DataGrid x:Name="DataGridZawodnicy" AutoGenerateColumns="False" 
                      ItemsSource="{Binding ZawodnikRecord.ZawodnikRecords}" 
                      CanUserAddRows="False" Height="220" Margin="5">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding ZawodnikId}" Width="40"/>
                    <DataGridTextColumn Header="Imię" Binding="{Binding Imie}" Width="120"/>
                    <DataGridTextColumn Header="Kondycja" Binding="{Binding Kondycja}" Width="80"/>
                    <DataGridTextColumn Header="Kontuzja" Binding="{Binding CzyKontuzja}" Width="80"/>
                    <DataGridTextColumn Header="Nr" Binding="{Binding NrKoszulki}" Width="50"/>
                    <DataGridTextColumn Header="Klub" Binding="{Binding KlubId}" Width="60"/>
                    <DataGridTextColumn Header="Stat" Binding="{Binding StatystykaId}" Width="60"/>

                    <DataGridTemplateColumn Width="75">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Wybierz" 
                                        Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding ZawodnikId}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="75">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Usuń" 
                                        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding ZawodnikId}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </StackPanel>
</Window>